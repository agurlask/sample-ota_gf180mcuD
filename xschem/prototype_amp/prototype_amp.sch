.control
save all
save @m.xm1.m0[id] @m.xm1.m0[gm] @m.xm1.m0[gds]
save @m.xm3.m0[id] @m.xm3.m0[gm] @m.xm3.m0[gds]
save @m.xm6.m0[id] @m.xm6.m0[gm] @m.xm6.m0[gds]
save @m.xm8.m0[id] @m.xm8.m0[gm] @m.xm8.m0[gds]

op
ac dec 10 1 1G

setplot ac1
let vdiff = v(vout_p) - v(vout_n)
write output.raw
.endc"}
